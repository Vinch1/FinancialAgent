# Environment Configuration
# Copy this file to `.env` and fill in your actual values

# ===========================================
# REQUIRED
# ===========================================

# Anthropic API Key - Required for Claude Agent SDK
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# OBSIDIAN MCP (Optional)
# ===========================================
# Requires Local REST API plugin installed in Obsidian
# Get API key from: Obsidian Settings > Community plugins > Local REST API

OBSIDIAN_API_KEY=your_obsidian_api_key_here
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27124

# ===========================================
# SERVER (Optional)
# ===========================================

# Server port (default: 3000)
PORT=3000
