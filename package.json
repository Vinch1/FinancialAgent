{
  "name": "docsearch",
  "version": "1.0.0",
  "description": "Personal assistant agent with Obsidian MCP and financial skills",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "node --loader ts-node/esm src/index.ts",
    "serve": "node dist/index.js",
    "build:backend": "tsc && pkg dist/index.js --targets node18-win-x64 --output src-tauri/binaries/docsearch-backend-x86_64-pc-windows-msvc.exe",
    "dev:desktop": "concurrently \"npm run dev\" \"npx tauri dev\"",
    "tauri:dev": "npm run build:backend && tauri dev",
    "tauri:build": "npm run build:backend && tauri build"
  },
  "keywords": [
    "claude",
    "agent",
    "obsidian",
    "mcp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.66",
    "@hono/node-server": "^1.19.10",
    "dotenv": "^16.4.5",
    "hono": "^4.12.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
